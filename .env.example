# =============================================================================
# Stransport Pro — Environment template (placeholders only; no real secrets)
# Copy to .env for local development. On Render, set these in the dashboard.
# =============================================================================

# Django (required in production)
SECRET_KEY=your-secret-key-here-change-in-production
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1
# ברשת (Render): חובה להוסיף את כתובת האתר ב‑HTTPS, אחרת יציאה/טפסים ייתנו 403 CSRF
# On production: must include your site URL over HTTPS, otherwise logout/forms get 403 CSRF
CSRF_TRUSTED_ORIGINS=http://localhost:8000,http://127.0.0.1:8000
# Production example: https://stransport-djm8.onrender.com
STATIC_ROOT=staticfiles
LOG_LEVEL=INFO

# Database (Render injects DATABASE_URL for Postgres)
DATABASE_URL=postgresql://user:password@host:5432/dbname
DB_NAME=stransport_db
DB_USER=stransport_user
DB_PASSWORD=stransport_password
DB_HOST=localhost
DB_PORT=5432
POSTGRES_DB=stransport_db
POSTGRES_USER=stransport_user
POSTGRES_PASSWORD=stransport_password

# RabbitMQ (if using Celery)
RABBITMQ_URL=amqp://guest:guest@rabbitmq:5672//
CELERY_RESULT_BACKEND=rpc://
STALE_REQUEST_MINUTES=30

# Redis (if using Channels/WebSockets)
REDIS_URL=redis://redis:6379/0

# Groq AI (Trivia app)
GROQ_API_KEY=your_groq_api_key_here

# AI summary for transport requests (optional)
AI_API_KEY=your_ai_api_key_here

# Google Maps / Places (browser key — used in frontend for address autocomplete & maps)
# This project uses a single key; set GOOGLE_PLACES_API_KEY. Restrict by HTTP referrer in Google Cloud.
GOOGLE_PLACES_API_KEY=your_google_places_api_key_here

# OSRM (route matrix)
OSRM_BASE_URL=https://router.project-osrm.org

# Docker Hub (for GitHub Actions)
DOCKER_USERNAME=your_dockerhub_username
