# Django Settings
SECRET_KEY=your-secret-key-here-change-in-production
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1
CSRF_TRUSTED_ORIGINS=http://localhost:8000,http://127.0.0.1:8000
STATIC_ROOT=staticfiles
LOG_LEVEL=INFO

# Database (Production uses Postgres)
DATABASE_URL=postgresql://stransport_user:stransport_password@db:5432/stransport_db
DB_NAME=stransport_db
DB_USER=stransport_user
DB_PASSWORD=stransport_password
DB_HOST=localhost
DB_PORT=5432
POSTGRES_DB=stransport_db
POSTGRES_USER=stransport_user
POSTGRES_PASSWORD=stransport_password

# RabbitMQ
RABBITMQ_URL=amqp://guest:guest@rabbitmq:5672//
CELERY_RESULT_BACKEND=rpc://
STALE_REQUEST_MINUTES=30

# Redis (Channels)
REDIS_URL=redis://redis:6379/0

# Groq AI API (Trivia)
GROQ_API_KEY=your_groq_api_key_here

# AI summary (optional)
AI_API_KEY=your_ai_api_key_here

# Google Places API (address autocomplete)
GOOGLE_PLACES_API_KEY=your_google_places_api_key_here

# OSRM (route matrix)
OSRM_BASE_URL=https://router.project-osrm.org

# Docker Hub (for GitHub Actions)
DOCKER_USERNAME=your_dockerhub_username
